{
  "name": "mmxpage",
  "version": "0.0.0",
  "description": "A markdown-style documentation generator, blog builder, and standalone page CLI",
  "main": "main.js",
  "type": "module",
  "bin": {
    "mmx": "cli.js"
  },
  "files": [
    "main.js",
    "cli.js",
    "template.html",
    "intAssets/",
    "scripts/",
    "LICENSE",
    "readme.md"
  ],
  "scripts": {
    "mmx": "bun cli.js",
    "dev": "bun --watch cli.js",
    "start": "bun cli.js",
    "node": "node cli.js"
  },
  "keywords": [
    "documentation",
    "markdown",
    "docs",
    "static-site",
    "blog",
    "mmx",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cp-mario/MMX"
  },
  "bugs": {
    "url": "https://github.com/cp-mario/MMX/issues"
  },
  "homepage": "https://github.com/cp-mario/MMX#readme",
  "author": "Mario",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.14"
}
