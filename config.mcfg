#This is the config of the parser
#Generates a complete documentation project with sidebar navigation

inputPath = "./1Example/input"
outputPath = "./1Example/output/"

#Minification options - set to false to disable, true to enable
#If you dont know what this does keep them as they are

#Minifies JavaScript files before copying to the output
minifyScripts = true

#Minifies CSS files before copying to the output
minifyCss = true